# Content generation mode: stub (no API) or ai (OpenAI)
CONTENT_MODE=stub

# OpenAI API key (required for ai mode)
OPENAI_API_KEY=sk-...

# Models
OPENAI_MODEL=gpt-4
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Response caching
ENABLE_CACHE=true
CACHE_TTL_DAYS=30

# Optional tuning
OPENAI_TEMPERATURE=0.9
OPENAI_MAX_TOKENS=4000
API_DELAY_MS=500
MAX_RETRIES=3
