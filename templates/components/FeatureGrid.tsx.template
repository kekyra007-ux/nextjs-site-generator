  }

  ${({ theme }) => theme.mq.lg} {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  @media (max-width: 360px) {
    gap: 0.85rem;
  }

  @media (max-width: 320px) {
    gap: 0.75rem;
  }
`;

const Card = styled.div`
  position: relative;
  border-radius: ${({ theme }) => theme.radii.xl};
  padding: 1.15rem 1.15rem 1.1rem;

  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.10),
    rgba(255, 255, 255, 0.06)
  );
  border: 2px solid ${({ theme }) => theme.colors.border};

  box-shadow:
    0 18px 40px rgba(0, 0, 0, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.10);

  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);

  transition:
    transform 180ms ease,
    box-shadow 180ms ease,
    border-color 180ms ease,
    background 180ms ease;

  &::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      420px 200px at 20% 0%,
      rgba(255, 255, 255, 0.14),
      transparent 55%
    );
    opacity: 0.9;
    pointer-events: none;
  }

  &::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    border: 1px solid rgba(0, 0, 0, 0.06);
    opacity: 0.55;
    mix-blend-mode: overlay;
  }

  &:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.20);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.20),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.07)
    );
  }

  /* touch: hover-подъёмы выглядят “дёргано”, убираем */
  @media (hover: none) {
    &:hover {
      transform: none;
    }
  }

  /* ultra small: меньше blur и паддинги */
  @media (max-width: 360px) {
    padding: 1rem;
    border-radius: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media (max-width: 320px) {
    padding: 0.95rem;
    backdrop-filter: blur(7px);
    -webkit-backdrop-filter: blur(7px);
  }
`;

const TitlePill = styled.div`
  display: inline-flex;
  align-items: center;

  padding: 0.45rem 0.7rem;
  border-radius: 999px;

  background: rgba(255, 255, 255, 0.10);
  border: 1px solid rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);

  box-shadow:
    0 10px 22px rgba(0, 0, 0, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.12);

  max-width: 100%;

  @media (max-width: 360px) {
    padding: 0.42rem 0.62rem;
  }

  @media (max-width: 320px) {
    padding: 0.4rem 0.58rem;
  }
`;

const TitlePillText = styled.h3`
  margin: 0;
  color: ${({ theme }) => theme.colors.text};
  font-size: clamp(1.0rem, 3.2vw, ${({ theme }) => theme.font.size.lg});
  font-weight: ${({ theme }) => theme.font.weight.semibold};
  letter-spacing: -0.01em;
  line-height: 1.15;

  text-shadow: 0 1px 0 rgba(0, 0, 0, 0.14);
  word-break: break-word;

  @media (max-width: 360px) {
    font-size: 1rem;
      text-align: center;

  }

  @media (max-width: 320px) {
    font-size: 0.98rem;
    line-height: 1.18;
  }
`;

const CardText = styled.p`
  margin: 0;
  color: ${({ theme }) => theme.colors.textMuted};
  line-height: 1.65;
  font-size: 0.98rem;

  @media (max-width: 360px) {
    font-size: 0.95rem;
  }
`;

function isFeatureGridData(v: unknown): v is FeatureGridData {
  if (!v || typeof v !== "object" || Array.isArray(v)) return false;
  const obj = v as any;
  return (
    typeof obj.title === "string" &&
    Array.isArray(obj.items) &&
    obj.items.every(
      (it: any) => it && typeof it.title === "string" && typeof it.text === "string"
    )
  );
}

const FeatureGrid = ({ page, sectionKey = "featureGrid" }: FeatureGridProps) => {
  const { t } = useTranslation("common");

  const raw = t(`sections.${sectionKey}.${page}`, { returnObjects: true });
  if (!isFeatureGridData(raw)) return null;

  return (
    <Section>
      <Container>
        <Title>{raw.title}</Title>
        <Grid>
          {raw.items.map((it, idx) => (
            <Card key={idx}>
<TitlePill>
  <TitlePillText>{it.title}</TitlePillText>
</TitlePill>              <CardText>{it.text}</CardText>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  );
};

export default FeatureGrid;