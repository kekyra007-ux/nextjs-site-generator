  background: ${({ theme }) => theme.colors.background};
  overflow: hidden;

  &::before {
    content: "";
    position: absolute;
    inset: -40px -40px auto -40px;
    height: 360px;
    background:
      radial-gradient(
        600px 260px at 20% 10%,
        rgba(255, 255, 255, 0.10),
        transparent 60%
      ),
      radial-gradient(
        520px 240px at 85% 35%,
        rgba(255, 255, 255, 0.07),
