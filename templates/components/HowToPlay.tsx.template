// src/components/Sections/HowToPlay/HowToPlay.tsx
import styled from "styled-components";
import { useTranslation } from "next-i18next";
import Button from "../../UI/Button";
import siteSettings from "../../../config/siteSettings.json";

interface HowToPlayProps {
  page: string;
  sectionKey?: string;
}

type StepItem = {
  step: string;
  title: string;
  description: string;
};

type HowToPlayData = {
  title: string;
  subtitle: string;
  steps: StepItem[];
  buttonText: string;
};

/* ───────── layout ───────── */

