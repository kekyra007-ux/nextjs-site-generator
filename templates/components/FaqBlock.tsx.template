import styled from "styled-components";
import { useTranslation } from "next-i18next";

interface FaqBlockProps {
  page: string;
  sectionKey?: string; // default: "faqBlock"
}

type FaqItem = { q: string; a: string };

type FaqData = {
  title: string;
  items: FaqItem[];
};

