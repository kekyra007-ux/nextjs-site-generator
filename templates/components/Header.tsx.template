// ---------- helpers ----------
const isHomeKey = (p: string) => p === "home" || p === "index";
const normalize = (p: string) => (p.endsWith("/") ? p.slice(0, -1) : p);

// гарантированно SOLID фон для хедера/дровера (не зависит от background-градиента страницы)
const surfaceBg = (theme: any) =>
  theme?.colors?.surface ||
  theme?.colors?.panel ||
  theme?.colors?.card ||
  theme?.colors?.backgroundLight ||
  "#0B0F1A";

const borderClr = (theme: any) =>
  theme?.colors?.border || "rgba(255,255,255,0.12)";

interface ActiveProps {
  $active?: boolean;
}

