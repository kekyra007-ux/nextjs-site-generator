// ---------- config (вставки из генератора) ----------
const PAGES: string[] = {{pagesArray}};
const LOCALES: string[] = {{localesArray}};

const PAGE_NAMES: Record<string, string> = {
  index: "Home",
  products: "Products",
  services: "Services",
  events: "Events",
  app: "App",
  offers: "Offers",
  login: "Login",
  register: "Register",
};

export const Header = () => {
  const router = useRouter();
  const locale = (router.query.locale as string) || "{{defaultLocale}}";
  const [open, setOpen] = useState(false);

  const navItems = useMemo(() => {
    return PAGES.map((page) => {
      const href = isHomeKey(page) ? "/" : `/${page}`;
      const label = PAGE_NAMES[page] || (isHomeKey(page) ? "Home" : page);
      return { href, label };
    });
  }, []);

  const isActive = (href: string) => {
    const currentPath = normalize(router.asPath);

    if (href === "/") {
      return (
        currentPath === `/${locale}` ||
        currentPath === `/${locale}/` ||
        currentPath === ""
      );
    }

    const target = normalize(`/${locale}${href}`);
    return currentPath === target || currentPath.startsWith(`${target}/`);
  };

  useEffect(() => {
    const handle = () => setOpen(false);
    router.events.on("routeChangeComplete", handle);
    return () => router.events.off("routeChangeComplete", handle);
  }, [router.events]);

  useEffect(() => {
    if (!open) return;
    const prev = document.body.style.overflow;
    document.body.style.overflow = "hidden";
    return () => {
      document.body.style.overflow = prev;
    };
  }, [open]);

  return (
    <HeaderShell>
      <HeaderBar>
        <Container>
          <Row>
            <Left>
              <Link href="/" passHref>
                <LogoA>
                  <strong>{{brandName}}</strong>
                </LogoA>
              </Link>

              <DesktopNav aria-label="Primary navigation">
                <NavList>
                  {navItems.map((item) => (
                    <li key={item.href}>
                      <Link href={item.href} passHref>
                        <NavA $active={isActive(item.href)}>{item.label}</NavA>
                      </Link>
                    </li>
                  ))}
                </NavList>
              </DesktopNav>
            </Left>

            <Right>
              <DesktopLang>
                {LOCALES.map((loc) => (
                  <Link key={loc} href="/" locale={loc}>
                    <Button
                      $variant={locale === loc ? "primary" : "secondary"}
                      size="small"
                    >
                      {loc.toUpperCase()}
                    </Button>
                  </Link>
                ))}
              </DesktopLang>

              <IconBtn
                type="button"
                aria-label={open ? "Close menu" : "Open menu"}
                aria-expanded={open}
                onClick={() => setOpen((v) => !v)}
              >
                <BurgerIcon open={open} />
              </IconBtn>
            </Right>
          </Row>
        </Container>
      </HeaderBar>

      <Overlay
        $open={open}
        onClick={() => setOpen(false)}
        aria-hidden={!open}
      />

      <Drawer $open={open} aria-label="Mobile navigation">
        <DrawerTop>
          <DrawerTitle>Menu</DrawerTitle>
          <IconBtn
            type="button"
            aria-label="Close menu"
            onClick={() => setOpen(false)}
          >
            <BurgerIcon open />
          </IconBtn>
        </DrawerTop>

        <DrawerLang>
          {LOCALES.map((loc) => (
            <Link key={loc} href="/" locale={loc}>
              <Button
                $variant={locale === loc ? "primary" : "secondary"}
                size="small"
              >
                {loc.toUpperCase()}
              </Button>
            </Link>
          ))}
        </DrawerLang>

        <DrawerNav>
          <DrawerList>
            {navItems.map((item) => (
              <li key={item.href}>
                <Link href={item.href} passHref>
                  <DrawerA
                    $active={isActive(item.href)}
                    onClick={() => setOpen(false)}
                  >
                    {item.label}
                  </DrawerA>
                </Link>
              </li>
            ))}
          </DrawerList>
        </DrawerNav>
      </Drawer>
    </HeaderShell>
  );
};

export default Header;