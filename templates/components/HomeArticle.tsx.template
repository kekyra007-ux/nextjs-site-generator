const Title = styled.h2`
  margin: 0 0 0.85rem;
  color: ${({ theme }) => theme.colors.text};
  font-family: ${({ theme }) => theme.font.family.heading};

  font-size: clamp(1.65rem, 3.6vw, ${({ theme }) => theme.font.size["3xl"]});
  font-weight: 900;
  letter-spacing: -0.02em;
  line-height: 1.08;

  text-wrap: balance;
  overflow-wrap: anywhere;

  /* лёгкая “выпуклость” заголовка */
  text-shadow:
    0 1px 0 rgba(0, 0, 0, 0.28),
    0 14px 32px rgba(0, 0, 0, 0.18);

  filter: saturate(1.05) contrast(1.02);

  @media (max-width: 360px) {
    margin-bottom: 0.75rem;
    line-height: 1.05;
  }
`;

const Subtitle = styled.p`
  margin: 0 0 1.25rem;
  color: ${({ theme }) => theme.colors.textMuted};

  font-size: clamp(0.98rem, 2.2vw, ${({ theme }) => theme.font.size.lg});
  line-height: 1.65;
  opacity: 0.95;

  max-width: 62ch;

  text-wrap: pretty;
  overflow-wrap: anywhere;

  @media (max-width: 360px) {
    margin-bottom: 1.05rem;
    max-width: 100%;
  }
`;

const P = styled.p`
  margin: 0 0 1rem;
  color: ${({ theme }) => theme.colors.textMuted};
  line-height: 1.78;
  font-size: clamp(0.98rem, 1.9vw, 1.05rem);
  opacity: 0.96;

  overflow-wrap: anywhere;
  text-wrap: pretty;

  @media (max-width: 360px) {
    line-height: 1.72;
    margin-bottom: 0.9rem;
  }
`;

const List = styled.ul`
  margin: 0 0 1rem;
  padding: 0; /* убираем стандартные отступы списка */
  list-style: none;

  display: grid;
  gap: 0.65rem;

  li {
    position: relative;
    margin: 0;

    padding: 0.9rem 0.95rem 0.9rem 1.2rem;
    border-radius: 16px;

    color: ${({ theme }) => theme.colors.textMuted};
    line-height: 1.65;

    /* “плашка” под тему */
    background:
      radial-gradient(
        520px 200px at 12% 0%,
        ${({ theme }) => theme.colors.primary}22,
        transparent 62%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.1),
        rgba(255, 255, 255, 0.06)
      );

    border: 1px solid rgba(255, 255, 255, 0.14);

    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);

    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);

    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;

    /* тонкая акцентная полоска слева */
    &::before {
      content: "";
      position: absolute;
      left: 10px;
      top: 10px;
      bottom: 10px;
      width: 4px;
      border-radius: 999px;
      background: linear-gradient(
        180deg,
        ${({ theme }) => theme.colors.primary},
        ${({ theme }) => theme.colors.secondary}
      );
      opacity: 0.9;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
    }

    &:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 255, 255, 0.2);
      background:
        radial-gradient(
          520px 220px at 12% 0%,
          ${({ theme }) => theme.colors.primary}2B,
