    filter: blur(2px);
  }

  /* тонкая “рамка” с акцентом */
  &::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;

    background: linear-gradient(
      135deg,
      ${({ theme }) => theme.colors.primary}55,
      transparent 45%,
      ${({ theme }) => theme.colors.secondary}55
    );
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
