  sectionKey?: string; // default: "homeArticle"
}

type HomeArticleData = {
  title: string;
  subtitle?: string;
  p1: string;
  p2?: string;
  list?: string[];
  p3?: string;

  buttonText?: string;
};

const Section = styled.section`
  padding: 3.5rem 1rem;
  background: ${({ theme }) => theme.colors.background};
`;

const Container = styled.div`
  max-width: ${({ theme }) => theme.container.maxWidth};
  margin: 0 auto;
  position: relative;
`;

const Box = styled.div`
  position: relative;
  overflow: hidden;

  border-radius: ${({ theme }) => theme.radii["2xl"]};
  padding: clamp(1.05rem, 3.2vw, 2.25rem);

  /* базовая панель (привязка к теме) */
  background:
    radial-gradient(
      680px 260px at 18% 0%,
      ${({ theme }) => theme.colors.primary}22,
      transparent 58%
    ),
    radial-gradient(
      540px 240px at 85% 24%,
      ${({ theme }) => theme.colors.secondary}1C,
      transparent 62%
    ),
    linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.06));

  border: 1px solid rgba(255, 255, 255, 0.14);

  box-shadow:
    0 22px 66px rgba(0, 0, 0, 0.22),
    0 0 0 1px rgba(255, 255, 255, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.12);

  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

  /* “акцентная дуга” сверху — яркость казино, но без колхоза */
  &::before {
    content: "";
    position: absolute;
    inset: -2px;
    pointer-events: none;
    border-radius: inherit;
    background:
      radial-gradient(
        900px 320px at 12% 0%,
