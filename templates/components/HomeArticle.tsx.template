const Actions = styled.div`
  margin-top: 1.25rem;
  display: flex;
  justify-content: flex-start;

  @media (max-width: 480px) {
    justify-content: stretch;

    a {
      width: 100%;
      justify-content: center;
    }
  }
`;
function isHomeArticleData(v: unknown): v is HomeArticleData {
  if (!v || typeof v !== "object" || Array.isArray(v)) return false;
  const o = v as any;

  // базовые обязательные поля
  if (typeof o.title !== "string" || typeof o.p1 !== "string") return false;

  // опциональные поля (если есть — должны быть правильного типа)
  if (o.subtitle != null && typeof o.subtitle !== "string") return false;
  if (o.p2 != null && typeof o.p2 !== "string") return false;
  if (o.p3 != null && typeof o.p3 !== "string") return false;

  if (o.list != null) {
    if (!Array.isArray(o.list)) return false;
    if (!o.list.every((x: any) => typeof x === "string")) return false;
  }

  if (o.buttonText != null && typeof o.buttonText !== "string") return false;

  return true;
}

const HomeArticle = ({
  page,
  sectionKey = "homeArticle",
}: HomeArticleProps) => {
  const { t } = useTranslation("common");
  const raw = t(`sections.${sectionKey}.${page}`, { returnObjects: true });
  if (!isHomeArticleData(raw)) return null;

  return (
    <Section>
      <Container>
        <Box>
          <Title>{raw.title}</Title>
          {raw.subtitle ? <Subtitle>{raw.subtitle}</Subtitle> : null}
          <P>{raw.p1}</P>
          {raw.p2 ? <P>{raw.p2}</P> : null}
          {Array.isArray(raw.list) && raw.list.length ? (
            <List>
              {raw.list.map((it, idx) => (
                <li key={idx}>{it}</li>
              ))}
            </List>
          ) : null}
          {raw.p3 ? <P>{raw.p3}</P> : null}
          <Actions>
            <Button
              $variant="primary"
              size="large"
              href={siteSettings.referralLink || "#"}
              target="_blank"
              rel="noopener noreferrer"
            >
              {raw.buttonText || "Play Now"}
            </Button>
          </Actions>{" "}
        </Box>
      </Container>
    </Section>
  );
};

export default HomeArticle;
